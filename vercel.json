{
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "Dockerfile.vercel"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": { "service": "backend" } },
    { "source": "/hubs/:path*", "destination": { "service": "backend" } },
    { "source": "/:path*", "destination": { "service": "frontend" } }
  ]
}
