{
  "openapi": "3.1.1",
  "info": {
    "title": "ComeRico.Api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registra un nuevo usuario e inicia sesión",
        "operationId": "Register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Inicia sesión con correo y contraseña",
        "operationId": "Login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Cierra la sesión actual",
        "operationId": "Logout",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Obtiene el usuario autenticado y su hogar",
        "operationId": "GetCurrentUser",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/households": {
      "post": {
        "tags": [
          "Households"
        ],
        "summary": "Crea un nuevo hogar y asigna al usuario como administrador",
        "operationId": "CreateHousehold",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHouseholdCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/households/join": {
      "post": {
        "tags": [
          "Households"
        ],
        "summary": "Une al usuario a un hogar mediante código de invitación",
        "operationId": "JoinHousehold",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinHouseholdCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/dishes": {
      "get": {
        "tags": [
          "Dishes"
        ],
        "summary": "Obtiene los platillos del hogar",
        "operationId": "GetDishes",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Dishes"
        ],
        "summary": "Crea un nuevo platillo",
        "operationId": "CreateDish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDishCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/dishes/{id}": {
      "put": {
        "tags": [
          "Dishes"
        ],
        "summary": "Actualiza un platillo existente",
        "operationId": "UpdateDish",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Dishes"
        ],
        "summary": "Elimina (desactiva) un platillo",
        "operationId": "DeleteDish",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/roulette/spin": {
      "post": {
        "tags": [
          "Roulette"
        ],
        "summary": "Gira la ruleta y retorna el platillo ganador",
        "operationId": "SpinRoulette",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/roulette/history": {
      "get": {
        "tags": [
          "Roulette"
        ],
        "summary": "Obtiene el historial de giros de la ruleta",
        "operationId": "GetRouletteHistory",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateDishCommand": {
        "required": [
          "name",
          "description",
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "imageUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateHouseholdCommand": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "JoinHouseholdCommand": {
        "required": [
          "inviteCode"
        ],
        "type": "object",
        "properties": {
          "inviteCode": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "required": [
          "displayName",
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "UpdateDishRequest": {
        "required": [
          "name",
          "description",
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "imageUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Households"
    },
    {
      "name": "Dishes"
    },
    {
      "name": "Roulette"
    }
  ]
}