{
  "openapi": "3.1.1",
  "info": {
    "title": "ComeRico.Api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registra un nuevo usuario e inicia sesión",
        "operationId": "Register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserDto"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Inicia sesión con correo y contraseña",
        "operationId": "Login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Cierra la sesión actual",
        "operationId": "Logout",
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Obtiene el usuario autenticado y su hogar",
        "operationId": "GetCurrentUser",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/households": {
      "post": {
        "tags": [
          "Households"
        ],
        "summary": "Crea un nuevo hogar y asigna al usuario como administrador",
        "operationId": "CreateHousehold",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHouseholdCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HouseholdDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/households/join": {
      "post": {
        "tags": [
          "Households"
        ],
        "summary": "Une al usuario a un hogar mediante código de invitación",
        "operationId": "JoinHousehold",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinHouseholdCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HouseholdDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/dishes": {
      "get": {
        "tags": [
          "Dishes"
        ],
        "summary": "Obtiene los platillos del hogar",
        "operationId": "GetDishes",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DishDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Dishes"
        ],
        "summary": "Crea un nuevo platillo",
        "operationId": "CreateDish",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDishCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DishDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/dishes/{id}": {
      "put": {
        "tags": [
          "Dishes"
        ],
        "summary": "Actualiza un platillo existente",
        "operationId": "UpdateDish",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDishRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DishDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "delete": {
        "tags": [
          "Dishes"
        ],
        "summary": "Elimina (desactiva) un platillo",
        "operationId": "DeleteDish",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/roulette/spin": {
      "post": {
        "tags": [
          "Roulette"
        ],
        "summary": "Gira la ruleta y retorna el platillo ganador",
        "operationId": "SpinRoulette",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpinRouletteResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/roulette/history": {
      "get": {
        "tags": [
          "Roulette"
        ],
        "summary": "Obtiene el historial de giros de la ruleta",
        "operationId": "GetRouletteHistory",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RouletteSessionDto"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateDishCommand": {
        "required": [
          "name",
          "description",
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "imageUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateHouseholdCommand": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "CurrentUserDto": {
        "required": [
          "id",
          "displayName",
          "email",
          "householdId",
          "householdName",
          "inviteCode",
          "role"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "householdId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "householdName": {
            "type": [
              "null",
              "string"
            ]
          },
          "inviteCode": {
            "type": [
              "null",
              "string"
            ]
          },
          "role": {
            "type": "string"
          }
        }
      },
      "DishDto": {
        "required": [
          "id",
          "householdId",
          "name",
          "description",
          "imageUrl",
          "isActive",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "householdId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "imageUrl": {
            "type": [
              "null",
              "string"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FieldError": {
        "required": [
          "field",
          "message"
        ],
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "HouseholdDto": {
        "required": [
          "id",
          "name",
          "inviteCode",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "inviteCode": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "JoinHouseholdCommand": {
        "required": [
          "inviteCode"
        ],
        "type": "object",
        "properties": {
          "inviteCode": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "required": [
          "displayName",
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RouletteSessionDto": {
        "required": [
          "id",
          "householdId",
          "status",
          "winnerDishId",
          "winnerDishName",
          "createdAt",
          "spunAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "householdId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string"
          },
          "winnerDishId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "winnerDishName": {
            "type": [
              "null",
              "string"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "spunAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "SpinRouletteResult": {
        "required": [
          "sessionId",
          "householdId",
          "winnerDishId",
          "winnerDishName",
          "spunAt"
        ],
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "householdId": {
            "type": "string",
            "format": "uuid"
          },
          "winnerDishId": {
            "type": "string",
            "format": "uuid"
          },
          "winnerDishName": {
            "type": "string"
          },
          "spunAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateDishRequest": {
        "required": [
          "name",
          "description",
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "imageUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ValidationErrorBody": {
        "required": [
          "errors"
        ],
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Households"
    },
    {
      "name": "Dishes"
    },
    {
      "name": "Roulette"
    }
  ]
}