{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "import"],
  "ignorePatterns": ["src/api"],
  "categories": {
    "correctness": "error",
    "nursery": "warn",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true,
    "node": true,
    "browser": true
  },
  "rules": {
    "react/react-compiler": "error",
    "react/react-in-jsx-scope": "off"
  }
}
